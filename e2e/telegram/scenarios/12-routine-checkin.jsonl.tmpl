# Проверяет настройку рутины и одну ежедневную проверку в теме «Рутины».
# Перед шагом wait_routine_card подготовь карточку через локальный control API:
# часы на 20:00 локального времени после настройки + POST /control/tick.
{"id":"select_routine","action":"select_chat","chat":"{{CHAT}}","message_thread_id":{{ROUTINE_THREAD_ID}}}
{"id":"open_routine_setup","action":"click_button","button_text":"✏️ Настроить рутину","timeout_ms":60000}
{"id":"wait_routine_prompt","action":"wait","timeout_ms":60000}
{"id":"send_routine_items","action":"send_text","text":"- зарядка\n- йога"}
{"id":"wait_routine_setup_cleanup","action":"wait","timeout_ms":5000}
{"id":"wait_routine_card","action":"assert_visible_text","text":"Рутина за","timeout_ms":120000}
{"id":"mark_first_done","action":"click_button","button_text":"✅ Да","message_text":"Рутина за","timeout_ms":60000}
{"id":"wait_second_item","action":"wait","timeout_ms":60000}
{"id":"mark_second_partial","action":"click_button","button_text":"🔸 Частично","message_text":"Рутина за","timeout_ms":60000}
{"id":"wait_reason_prompt","action":"assert_visible_text","text":"Что помешало?","timeout_ms":60000}
{"id":"send_reason","action":"send_text","text":"Сорвался график."}
{"id":"wait_routine_table","action":"wait","timeout_ms":90000}
