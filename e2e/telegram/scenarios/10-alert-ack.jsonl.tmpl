# Covers acknowledging an already-dispatched daily-task alert in the Today topic.
# Precondition: a visible alert card with the "👀 Понял" button already exists.
{"id":"select_today","action":"select_chat","chat":"{{CHAT}}","message_thread_id":{{TODAY_THREAD_ID}}}
